<Window x:Class="KittyFocus.Windows.DeathOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="#AA111111"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="200"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 暗色遮罩 -->
        <Rectangle Fill="#E6111111"/>

        <!-- 中央失败面板 -->
        <Border Background="#FFFBF6F0" CornerRadius="24" Padding="50,40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="460" BorderBrush="#FFDDCCBB" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#44000000" BlurRadius="30" ShadowDepth="4"/>
            </Border.Effect>

            <StackPanel>
                <!-- 猫受伤 -->
                <TextBlock Text="😿" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <!-- 标题 -->
                <TextBlock x:Name="TitleText" Text="专注失败" FontSize="34" FontWeight="Bold"
                           Foreground="#FF4A3526" HorizontalAlignment="Center" Margin="0,0,0,8"/>

                <TextBlock x:Name="SubtitleText" Text="猫咪离开了你…" FontSize="15"
                           Foreground="#FF8A6A52" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                <TextBlock x:Name="DescriptionText" Text="命数耗尽，本次专注已因违规程序而中断" FontSize="13"
                           Foreground="#FFB59B82" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>

                <!-- 违规程序名 -->
                <Border Background="#FFF0E6DA" CornerRadius="8" Padding="14,8"
                        HorizontalAlignment="Center" Margin="0,16,0,24">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " FontSize="15" Foreground="#FFCC6633"/>
                        <TextBlock x:Name="ProcessNameText" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#FF4A3526" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 确认按钮 -->
                <Button Content="我明白了"
                        Background="#FF8A6A52" Foreground="White"
                        Click="AcknowledgeButton_Click"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
