<Window x:Class="KittyFocus.Windows.DeathOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="#AA111111"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 半透明暗色底层 -->
        <Rectangle Fill="#CC111111"/>

        <!-- 中央内容 -->
        <Border Background="#FFFBF6F0" CornerRadius="20" Padding="50,40"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                MaxWidth="480" BorderBrush="#FFDDCCBB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="💀" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="猫咪阵亡" FontSize="32" FontWeight="Bold"
                           Foreground="#FF4A3526" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="检测到违规程序，猫咪受到了严重伤害……" FontSize="14"
                           Foreground="#FF8A6A52" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>

                <Border Background="#FFF0E6DA" CornerRadius="8" Padding="12,6"
                        HorizontalAlignment="Center" Margin="0,10,0,20">
                    <TextBlock x:Name="ProcessNameText" FontSize="14" FontWeight="SemiBold"
                               Foreground="#FFCC6633" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="请关闭违规程序以保护猫咪，或点击下方按钮继续。" FontSize="12"
                           Foreground="#FFB59B82" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20"/>

                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="AcknowledgeButton" Grid.Column="0"
                            Content="已知晓" Background="#FF8A6A52" Foreground="White"
                            Click="AcknowledgeButton_Click"/>
                    <Button x:Name="KillButton" Grid.Column="1"
                            Content="关闭违规程序" Background="#FFE05A5A" Foreground="White"
                            Click="KillButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
