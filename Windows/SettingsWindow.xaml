<Window x:Class="KittyFocus.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="黑名单设置" Height="460" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFFBF6F0"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#FF6B4226"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="AddButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FF5BB85B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Width" Value="26"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#FFE05A5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="⚙ 黑名单设置" FontSize="18" FontWeight="Bold"
                   Foreground="#FF6B4226" Margin="0,0,0,14"/>
        <TextBlock Grid.Row="0" Text="专注进行时检测到以下程序/窗口标题将触发警告" FontSize="11"
                   Foreground="#FFB59B82" Margin="0,30,0,0"/>

        <!-- 进程名黑名单 -->
        <Border Grid.Row="1" Background="#FFF5EDE4" CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="黑名单进程名（如 League of Legends.exe）" Style="{StaticResource SectionTitle}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBox x:Name="ProcessInput" Width="280" FontSize="13" Padding="4,2"
                             VerticalContentAlignment="Center"/>
                    <Button Content="＋ 添加" Style="{StaticResource AddButtonStyle}"
                            Margin="8,0,0,0" Click="AddProcess_Click"/>
                </StackPanel>

                <ListBox x:Name="ProcessListBox" Grid.Row="2"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" CornerRadius="6" Padding="10,4"
                                    Margin="0,2" BorderBrush="#FFE0D6C8" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="#FF4A3526" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="✕" Style="{StaticResource DeleteButtonStyle}"
                                            Tag="{Binding}" Click="DeleteProcess_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 窗口标题关键词 -->
        <Border Grid.Row="2" Background="#FFF5EDE4" CornerRadius="10" Padding="14,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="窗口标题关键词（如 Bilibili）" Style="{StaticResource SectionTitle}"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBox x:Name="KeywordInput" Width="280" FontSize="13" Padding="4,2"
                             VerticalContentAlignment="Center"/>
                    <Button Content="＋ 添加" Style="{StaticResource AddButtonStyle}"
                            Margin="8,0,0,0" Click="AddKeyword_Click"/>
                </StackPanel>

                <ListBox x:Name="KeywordListBox" Grid.Row="2"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFFFFF" CornerRadius="6" Padding="10,4"
                                    Margin="0,2" BorderBrush="#FFE0D6C8" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="#FF4A3526" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="✕" Style="{StaticResource DeleteButtonStyle}"
                                            Tag="{Binding}" Click="DeleteKeyword_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="关闭" Width="90" Height="36" FontSize="14"
                    Background="#FF8A6A52" Foreground="White" Cursor="Hand"
                    BorderThickness="0" Click="CloseButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Grid>
</Window>
