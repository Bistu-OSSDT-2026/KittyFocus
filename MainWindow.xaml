<Window x:Class="KittyFocus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="专注猫灵 · 九命专注助手" Height="520" Width="420"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#FFFBF6F0">
    <Window.Resources>
        <!-- 主按钮样式：开始专注（绿） -->
        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="Background" Value="#FF5BB85B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFB9D8B9"/>
                    <Setter Property="Foreground" Value="#FFEEEEEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 强制结束按钮（红） -->
        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Background" Value="#FFE05A5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFD8A9A9"/>
                    <Setter Property="Foreground" Value="#FFEEEEEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 + 设置按钮 -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                <TextBlock Text="🐱" FontSize="26" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="专注猫灵 · 九命专注助手" FontSize="18" FontWeight="Bold"
                           Foreground="#FF6B4226" VerticalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="SettingsButton" Content="⚙" HorizontalAlignment="Right"
                    Width="36" Height="36" FontSize="18" Cursor="Hand"
                    Background="Transparent" Foreground="#FF8A6A52"
                    BorderThickness="0" Click="SettingsButton_Click"
                    ToolTip="黑名单设置"/>
        </Grid>

        <!-- 状态标签 -->
        <Border Grid.Row="1" Margin="0,14,0,0" Padding="14,5" CornerRadius="12"
                Background="#FFF0E6DA" HorizontalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="空闲中" FontSize="13"
                       Foreground="#FF8A6A52" FontWeight="SemiBold"/>
        </Border>

        <!-- 超大号倒计时 -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="CountdownText" Text="25:00" FontSize="78" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#FF4A3526">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#22FFA75F" BlurRadius="18" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock x:Name="HintText" Text="设置时长后点击开始" FontSize="12"
                       Foreground="#FFB59B82" HorizontalAlignment="Center" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 时长设置区 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,18">
            <TextBlock Text="专注时长" FontSize="13" Foreground="#FF8A6A52" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="DurationTextBox" Width="90" FontSize="18" Padding="6,4"
                         VerticalContentAlignment="Center" TextAlignment="Center"
                         PreviewTextInput="DurationTextBox_PreviewTextInput"
                         DataObject.Pasting="DurationTextBox_Pasting"/>
                <TextBlock Text="分钟" FontSize="14" Foreground="#FF8A6A52"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock Text="范围 1 ~ 720 分钟" FontSize="11" Foreground="#FFB59B82"
                           VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 控制按钮 -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="StartButton" Grid.Column="0" Content="开始专注" Margin="0,0,6,0"
                    Style="{StaticResource StartButton}" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Grid.Column="1" Content="强制结束" Margin="6,0,0,0"
                    Style="{StaticResource StopButton}" Click="StopButton_Click" IsEnabled="False"/>
        </Grid>
    </Grid>
</Window>
