<Window x:Class="KittyFocus.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="KittyFocus" Height="560" Width="474"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#FFFBF6F0"
        WindowStyle="None"
        AllowsTransparency="True">

    <!-- 圆角裁剪 + 阴影 -->
    <Window.Resources>
        <!-- 主按钮样式：开始专注（绿） -->
        <Style x:Key="StartButton" TargetType="Button">
            <Setter Property="Background" Value="#FF5BB85B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFB9D8B9"/>
                    <Setter Property="Foreground" Value="#FFEEEEEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 强制结束按钮（红） -->
        <Style x:Key="StopButton" TargetType="Button">
            <Setter Property="Background" Value="#FFE05A5A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FFD8A9A9"/>
                    <Setter Property="Foreground" Value="#FFEEEEEE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 黑名单管理按钮（黑） -->
        <Style x:Key="BlacklistButton" TargetType="Button">
            <Setter Property="Background" Value="#FF3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="120"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 外层圆角边框 -->
    <Border Background="#FFFBF6F0" CornerRadius="16"
            BorderBrush="#FFE0D5C8" BorderThickness="1"
            Margin="8" Padding="20,24">
        <Border.Effect>
            <DropShadowEffect Color="#33000000" BlurRadius="16" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0 标题 -->
                <RowDefinition Height="Auto"/>
                <!-- 1 圆环倒计时 -->
                <RowDefinition Height="Auto"/>
                <!-- 2 猫咪命数 -->
                <RowDefinition Height="*"/>
                <!-- 3 猫咪吉祥物 + 提示 -->
                <RowDefinition Height="Auto"/>
                <!-- 4 专注时长 -->
                <RowDefinition Height="Auto"/>
                <!-- 5 控制按钮 -->
            </Grid.RowDefinitions>

            <!-- 第一行：标题（居中） -->
            <StackPanel Grid.Row="0" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="🐱" FontSize="20" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="KittyFocus" FontSize="22" FontWeight="Bold"
                           Foreground="#FF6B4226" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 第二行：圆环倒计时（居中） -->
            <Canvas Grid.Row="1" Width="100" Height="100"
                    HorizontalAlignment="Center" Margin="0,0,0,4">
                <!-- 环状进度条背景（淡粉色底环） -->
                <Ellipse Stroke="#FFEDD5D5" StrokeThickness="6"
                         Width="88" Height="88"
                         Canvas.Left="6" Canvas.Top="6"/>

                <!-- 环状进度条前景（深粉色弧，与底环同心同径） -->
                <Path x:Name="ProgressArc"
                      Stroke="#FFC9A9B8" StrokeThickness="6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"/>

                <!-- 圆圈内的粉色倒计时 -->
                <TextBlock x:Name="CountdownText" Text="25:00"
                           FontSize="16" FontWeight="Bold"
                           Canvas.Left="0" Width="100" Height="100"
                           TextAlignment="Center"
                           Foreground="#FFF28CB1" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Top="34">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#44F28CB1" BlurRadius="6" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Canvas>

            <!-- 第三行：猫咪命数（居中、显眼） -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,2,0,10">
                <TextBlock Text="猫咪命数" FontSize="11" Foreground="#FFB59B82"
                           HorizontalAlignment="Center" Margin="0,0,0,3"/>
                <!-- 🐱=存活，🖤=已失去；命数过多时改为紧凑文字，避免横向溢出 -->
                <ItemsControl x:Name="LivesIndicator" FontSize="22"
                              HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StackPanel>

            <!-- 第四行：猫咪吉祥物 + 提示词 -->
            <StackPanel Grid.Row="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🐱" FontSize="96"/>
                <TextBlock x:Name="HintText" Text="设置时长后点击开始"
                           FontSize="13" Foreground="#FFB59B82"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <!-- 第五行：专注时长输入白框 -->
            <Grid Grid.Row="4" Margin="0,6,0,16">
                <Border Background="White" CornerRadius="10"
                        BorderBrush="#FFE0D5C8" BorderThickness="1"
                        HorizontalAlignment="Center" Padding="14,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox x:Name="DurationTextBox"
                                 Width="60" FontSize="16" Padding="4,2"
                                 VerticalContentAlignment="Center" TextAlignment="Center"
                                 Background="Transparent" BorderThickness="0"
                                 PreviewTextInput="DurationTextBox_PreviewTextInput"
                                 DataObject.Pasting="DurationTextBox_Pasting"
                                 TextChanged="DurationTextBox_TextChanged"/>
                        <TextBlock Text="分钟" FontSize="13" Foreground="#FF8A6A52"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 第六行：三个按钮 -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                <Button x:Name="StartButton" Content="开始专注"
                        Style="{StaticResource StartButton}" Margin="0,0,8,0"
                        Click="StartButton_Click"/>
                <Button x:Name="StopButton" Content="强制结束"
                        Style="{StaticResource StopButton}" Margin="0,0,8,0"
                        Click="StopButton_Click" IsEnabled="False"/>
                <Button x:Name="BlacklistButton" Content="黑名单管理"
                        Style="{StaticResource BlacklistButton}"
                        Click="SettingsButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
